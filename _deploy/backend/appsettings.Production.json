{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=KPITrackerAPI;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY",
    "Issuer": "KPITrackerAPI",
    "Audience": "KPITrackerClient",
    "AccessTokenExpirationHours": "3",
    "RefreshTokenExpirationDays": "7"
  },
  "App": {
    "ClientUrl": "https://YOUR_DOMAIN"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://YOUR_DOMAIN"
    ]
  },
  "EnableHttpsRedirection": true
}
